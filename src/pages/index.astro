---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Image from 'astro/components/Image.astro'
import { Image } from 'astro:assets'
import { ChevronsRight } from '@lucide/astro'
---

<BaseLayout
    title="Damien Site"
    description="Welcome to Damien Site"
    bodyClass="bg-[#000B17]"
>
    <div class="p-5 fixed top-0 z-50 w-full">
        <nav
            class="w-full p-4 lg:p-6 flex items-center justify-between gap-4 border border-white/20 rounded-2xl"
        >
            <div>
                <Image
                    src={import('@/assets/logo-nav.svg')}
                    alt={'Damien Duhamel'}
                />
            </div>
            <ul
                class="flex items-center gap-4 lg:gap-8 [&_li]:tracking-widest [&_li]:font-light [&_li]:text-white/80 [&_li]:hover:text-white [&_li]:uppercase"
            >
                <li><a href="#">Home</a></li>
                <li><a href="#">About</a></li>
                <li><a href="#">Insights</a></li>
                <li><a href="#">Contact</a></li>
            </ul>
        </nav>
    </div>
    <main>
        <section
            id="hero"
            class="px-4 lg:px-5 relative min-h-dvh flex flex-col h-full justify-end overflow-hidden"
        >
            <Image
                src={import('@/assets/hero-bg.png')}
                alt="hero background"
                class="absolute inset-0 lg:min-w-dvw object-cover"
            />
            <div
                class="relative flex flex-col items-center justify-end py-24 h-full"
            >
                <h1
                    class="text-white font-serif text-2xl lg:text-[40px] text-center inline-flex flex-col"
                >
                    <span class="italic">Middle East & Asia</span>
                    <span
                        class="uppercase font-sans font-bold text-4xl lg:text-8xl"
                        >Transformation</span
                    >
                    <span class="italic">Strategy</span>
                </h1>
                <p class="text-base text-white/75 mt-5 lg:mt-10 text-center">
                    Help clients build long-lasting competitive advantage and
                    accelerate profitable growth<br />
                    in the dynamic and complex markets of Asia and the Middle East.
                </p>
            </div>
            <div class="flex flex-col items-center justify-center gap-1">
                <span
                    class="text-white font-light text-xs text-center tracking-widest uppercase"
                    >Scroll</span
                >
                <div
                    class="w-px h-6 bg-linear-to-b from-white toto-transparent"
                >
                </div>
            </div>
        </section>
        <section id="categories" class="px-4 lg:px-5 py-10">
            <div class="flex gap-4 lg:gap-5">
                <div
                    class="group relative overflow-hidden p-4 md:p-6 lg:p-7.5 rounded-lg lg:rounded-2xl lg:w-1/3 hover:lg:w-10/12 duration-500 ease-out border border-white/10 lg:min-h-180 flex items-end justify-start"
                >
                    <Image
                        src={import('@/assets/publication.png')}
                        alt=""
                        class="absolute size-full inset-0 object-cover"
                    />
                    <div
                        class="absolute bg-linear-to-b from-[#001246]/0 via-[#076A80]/10 to-[#001246]/50 via-75% to-90% size-full inset-0"
                    >
                    </div>
                    <div class="flex justify-between items-center relative w-full">
                        <h2
                            class="uppercase text-2xl lg:text-4xl font-bold text-white leading-[0.9] tracking-tighter"
                        >
                            Publications
                        </h2>
                        <div
                            class="rounded-full bg-[#0DBFE6]/20 hover:bg-[#0DBFE6] duration-300 ease-out shrink-0 size-12 flex items-center justify-center opacity-0 group-hover:opacity-100"
                        >
                            <ChevronsRight class="size-4 lg:size-6 text-white" />
                        </div>
                    </div>
                </div>
                <div
                    class="group relative overflow-hidden p-4 md:p-6 lg:p-7.5 rounded-lg lg:rounded-2xl lg:w-1/3 hover:lg:w-10/12 duration-500 ease-out border border-white/10 lg:min-h-180 flex items-end justify-start"
                >
                    <Image
                        src={import('@/assets/in-the-news.png')}
                        alt=""
                        class="absolute size-full inset-0 object-cover"
                    />
                    <div
                        class="absolute bg-linear-to-b from-[#001246]/0 via-[#076A80]/10 to-[#001246]/50 via-75% to-90% size-full inset-0"
                    >
                    </div>
                    <div class="flex justify-between items-center relative w-full">
                        <h2
                            class="uppercase text-2xl lg:text-4xl font-bold text-white leading-[0.9] tracking-tighter"
                        >
                            In the News
                        </h2>
                        <div
                            class="rounded-full bg-[#0DBFE6]/20 hover:bg-[#0DBFE6] duration-300 ease-out shrink-0 size-12 flex items-center justify-center opacity-0 group-hover:opacity-100"
                        >
                            <ChevronsRight class="size-4 lg:size-6 text-white" />
                        </div>
                    </div>
                </div>
                <div
                    class="group relative overflow-hidden p-4 md:p-6 lg:p-7.5 rounded-lg lg:rounded-2xl lg:w-1/3 hover:lg:w-10/12 duration-500 ease-out border border-white/10 lg:min-h-180 flex items-end justify-start"
                >
                    <Image
                        src={import('@/assets/speaker.png')}
                        alt=""
                        class="absolute size-full inset-0 object-cover"
                    />
                    <div
                        class="absolute bg-linear-to-b from-[#001246]/0 via-[#076A80]/10 to-[#001246]/50 via-75% to-90% size-full inset-0"
                    >
                    </div>
                    <div class="flex justify-between items-center relative w-full">
                        <h2
                            class="uppercase text-2xl lg:text-4xl font-bold text-white leading-[0.9] tracking-tighter"
                        >
                            Speakers
                        </h2>
                        <div
                            class="rounded-full bg-[#0DBFE6]/20 hover:bg-[#0DBFE6] duration-300 ease-out shrink-0 size-12 flex items-center justify-center opacity-0 group-hover:opacity-100"
                        >
                            <ChevronsRight class="size-4 lg:size-6 text-white" />
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>
